# Cabeçalhos de segurança e cache (Netlify) — aplicados a todo o site.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=(), payment=()
  Strict-Transport-Security: max-age=31536000
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; frame-src https://www.google.com https://maps.google.com; connect-src 'self' https://www.google-analytics.com https://region1.google-analytics.com https://www.googletagmanager.com; form-action 'self'; base-uri 'self'; object-src 'none'; upgrade-insecure-requests

# Imagens/ilustrações (com ?v= no HTML) podem ter cache longa.
/assets/*
  Cache-Control: public, max-age=31536000
# CSS/JS partilhados: revalidar sempre para as atualizações chegarem já
# (o servidor responde 304 se nada mudou — rápido e sempre fresco).
/estilos.css
  Cache-Control: public, max-age=0, must-revalidate
/avo-widget.js
  Cache-Control: public, max-age=0, must-revalidate
/site.js
  Cache-Control: public, max-age=0, must-revalidate
